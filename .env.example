# Template for local development secrets.
# Copy to .env and replace all placeholder values before starting the application.
# .env is never committed — only this file is.
#
# Used by:
#   - Docker Compose (docker compose up -d)
#   - Spring Boot (loaded automatically via spring.config.import in application.yml)

# PostgreSQL
POSTGRES_DB=owasp_playground
POSTGRES_USER=owasp_user
POSTGRES_PASSWORD=change_me           # replace with a strong password

# Redis
REDIS_PASSWORD=change_me              # replace with a strong password

# JWT signing key (HMAC-SHA-256, must be >= 256 bits / 32 bytes when decoded)
# Generate: openssl rand -base64 32
JWT_SECRET=change_me                  # replace with generated value
